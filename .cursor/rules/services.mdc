## 6. VectorService (Embeddings + Search)

### Responsibilities
- Generate embeddings for transcript segments and summaries
- Store embeddings in SQLite (or dedicated vector DB)
- Perform semantic search (RAG pipeline)
- Return results with citations (recording ID, timestamp, speaker)

### Service Implementation
**File:** `src/main/services/VectorService.ts`

```typescript
import Database from 'better-sqlite3'
import { app } from 'electron'
import path from 'path'
import type { TranscriptSegment, SearchResult } from '@shared/types'

export class VectorService {
  private db: Database.Database
  private embeddingModel: any  // TODO: Load local embedding model (e.g., MiniLM ONNX)
  
  constructor() {
    const dbPath = path.join(app.getPath('userData'), 'vectors.db')
    this.db = new Database(dbPath)
    this.initialize()
  }
  
  private initialize(): void {
    this.db.exec(`
      CREATE TABLE IF NOT EXISTS embeddings (
        id TEXT PRIMARY KEY,
        recordingId TEXT NOT NULL,
        segmentId TEXT,
        text TEXT NOT NULL,
        embedding BLOB NOT NULL,
        metadata TEXT
      );
      
      CREATE INDEX IF NOT EXISTS idx_embeddings_recording ON embeddings(recordingId);
    `)
    
    // TODO: Load embedding model (e.g., all-MiniLM-L6-v2)
    // this.embeddingModel = await loadOnnxModel('all-MiniLM-L6-v2.onnx')
  }
  
  /**
   * Generate embedding for text
   */
  private async embed(text: string): Promise<Float32Array> {
    // TODO: Implement with local embedding model
    // For now, return random vector
    return new Float32Array(384).map(() => Math.random())
  }
  
  /**
   * Add transcript segments to vector store
   */
  async addSegments(segments: TranscriptSegment[]): Promise<void> {
    const insert = this.db.prepare(`
      INSERT INTO embeddings (id, recordingId, segmentId, text, embedding, metadata)
      VALUES (?, ?, ?, ?, ?, ?)
    `)
    
    const insertMany = this.db.transaction(async (segments: TranscriptSegment[]) => {
      for (const seg of segments) {
        const embedding = await this.embed(seg.text)
        const embeddingBuffer = Buffer.from(embedding.buffer)
        
        insert.run(
          `emb-${seg.id}`,
          seg.recordingId,
          seg.id,
          seg.text,
          embeddingBuffer,
          JSON.stringify({ speaker: seg.speaker, startTime: seg.startTime })
        )
      }
    })
    
    await insertMany(segments)
  }
  
  /**
   * Semantic search
   */
  async search(query: string, limit = 10): Promise<SearchResult[]> {
    const queryEmbedding = await this.embed(query)
    
    // ✅ Get all embeddings and compute cosine similarity
    const stmt = this.db.prepare('SELECT * FROM embeddings')
    const allEmbeddings = stmt.all() as any[]
    
    const results = allEmbeddings.map(row => {
      const embedding = new Float32Array(row.embedding.buffer)
      const similarity = this.cosineSimilarity(queryEmbedding, embedding)
      
      return {
        recordingId: row.recordingId,
        segmentId: row.segmentId,
        text: row.text,
        metadata: JSON.parse(row.metadata),
        similarity
      }
    })
    
    // Sort by similarity and return top results
    return results
      .sort((a, b) => b.similarity - a.similarity)
      .slice(0, limit)
  }
  
  /**
   * Cosine similarity
   */
  private cosineSimilarity(a: Float32Array, b: Float32Array): number {
    let dot = 0
    let normA = 0
    let normB = 0
    
    for (let i = 0; i < a.length; i++) {
      dot += a[i] * b[i]
      normA += a[i] * a[i]
      normB += b[i] * b[i]
    }
    
    return dot / (Math.sqrt(normA) * Math.sqrt(normB))
  }
  
  cleanup(): void {
    this.db.close()
  }
}
```

