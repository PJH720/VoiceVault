## 1. AudioCaptureService (native-audio-node / CoreAudio)

### Responsibilities
- Capture audio from microphone and/or system audio (macOS CoreAudio, Linux PulseAudio, Windows WASAPI)
- Voice Activity Detection (VAD) to filter silence
- Real-time PCM streaming to renderer (waveform visualization)
- Save raw audio to disk (WAV format)

### Dependencies
```json
{
  "native-audio-node": "^1.0.0"  // CoreAudio bindings for Node.js
}
```

### Service Implementation
**File:** `src/main/services/AudioCaptureService.ts`

```typescript
import { EventEmitter } from 'events'
import fs from 'fs'
import path from 'path'
import { app } from 'electron'
import NativeAudio from 'native-audio-node'
import type { AudioConfig, AudioChunk } from '@shared/types'

export class AudioCaptureService extends EventEmitter {
  private stream: NativeAudio.InputStream | null = null
  private audioBuffer: Buffer[] = []
  private isCapturing = false
  private outputPath: string | null = null
  private sampleRate = 16000  // Whisper requires 16kHz
  
  constructor() {
    super()
  }
  
  /**
   * Get available audio input devices
   */
  getDevices(): Promise<NativeAudio.Device[]> {
    return NativeAudio.getDevices()
  }
  
  /**
   * Start capturing audio from specified device
   */
  async startCapture(config: AudioConfig): Promise<void> {
    if (this.isCapturing) {
      throw new Error('Capture already in progress')
    }
    
    this.isCapturing = true
    this.audioBuffer = []
    
    // Generate output path
    const timestamp = Date.now()
    const userDataPath = app.getPath('userData')
    this.outputPath = path.join(userDataPath, 'recordings', `${timestamp}.wav`)
    
    // Ensure directory exists
    await fs.promises.mkdir(path.dirname(this.outputPath), { recursive: true })
    
    // Create native audio stream
    this.stream = NativeAudio.createInputStream({
      deviceId: config.deviceId,
      sampleRate: this.sampleRate,
      channels: 1,  // Mono for Whisper
      format: 'float32',  // PCM float32
      bufferSize: 4096
    })
    
    // ✅ Stream audio chunks to renderer + accumulate for saving
    this.stream.on('data', (chunk: Buffer) => {
      this.audioBuffer.push(chunk)
      
      // Emit to renderer for waveform visualization
      this.emit('chunk', {
        data: chunk,
        timestamp: Date.now()
      } as AudioChunk)
    })
    
    this.stream.on('error', (error: Error) => {
      console.error('[AudioCaptureService] Stream error:', error)
      this.emit('error', error)
    })
    
    // Start the stream
    this.stream.start()
    console.log('[AudioCaptureService] Capture started:', this.outputPath)
  }
  
  /**
   * Stop capturing and save audio file
   */
  async stopCapture(): Promise<string> {
    if (!this.isCapturing || !this.stream) {
      throw new Error('No active capture')
    }
    
    this.stream.stop()
    this.stream = null
    this.isCapturing = false
    
    // ✅ Write accumulated audio to WAV file
    const audioData = Buffer.concat(this.audioBuffer)
    await this.writeWavFile(this.outputPath!, audioData)
    
    console.log('[AudioCaptureService] Capture stopped, saved to:', this.outputPath)
    
    const savedPath = this.outputPath!
    this.outputPath = null
    this.audioBuffer = []
    
    return savedPath
  }
  
  /**
   * Write PCM audio data as WAV file
   */
  private async writeWavFile(outputPath: string, pcmData: Buffer): Promise<void> {
    // WAV header (44 bytes)
    const header = Buffer.alloc(44)
    const dataSize = pcmData.length
    const fileSize = dataSize + 44
    
    // "RIFF" chunk
    header.write('RIFF', 0)
    header.writeUInt32LE(fileSize - 8, 4)
    header.write('WAVE', 8)
    
    // "fmt " subchunk
    header.write('fmt ', 12)
    header.writeUInt32LE(16, 16)  // Subchunk1Size (16 for PCM)
    header.writeUInt16LE(3, 20)   // AudioFormat (3 = IEEE float)
    header.writeUInt16LE(1, 22)   // NumChannels (1 = mono)
    header.writeUInt32LE(this.sampleRate, 24)  // SampleRate
    header.writeUInt32LE(this.sampleRate * 4, 28)  // ByteRate (SampleRate * BlockAlign)
    header.writeUInt16LE(4, 32)   // BlockAlign (NumChannels * BitsPerSample / 8)
    header.writeUInt16LE(32, 34)  // BitsPerSample (32 for float32)
    
    // "data" subchunk
    header.write('data', 36)
    header.writeUInt32LE(dataSize, 40)
    
    // Write header + PCM data
    await fs.promises.writeFile(outputPath, Buffer.concat([header, pcmData]))
  }
  
  /**
   * Cleanup resources
   */
  cleanup(): void {
    if (this.stream) {
      this.stream.stop()
      this.stream = null
    }
    this.audioBuffer = []
    this.removeAllListeners()
  }
}
```

### IPC Handler
**File:** `src/main/ipc/audio.ts`

```typescript
import { ipcMain, BrowserWindow } from 'electron'
import { IpcChannels } from '@shared/ipc-channels'
import { AudioCaptureService } from '@main/services/AudioCaptureService'

export function registerAudioHandlers(
  audioService: AudioCaptureService,
  mainWindow: BrowserWindow
): void {
  // Get available devices
  ipcMain.handle(IpcChannels.AUDIO_GET_DEVICES, async () => {
    return audioService.getDevices()
  })
  
  // Start capture
  ipcMain.handle(IpcChannels.AUDIO_START, async (event, config) => {
    await audioService.startCapture(config)
  })
  
  // Stop capture
  ipcMain.handle(IpcChannels.AUDIO_STOP, async () => {
    const audioPath = await audioService.stopCapture()
    return audioPath
  })
  
  // ✅ Stream audio chunks to renderer
  audioService.on('chunk', (chunk) => {
    mainWindow.webContents.send(IpcChannels.AUDIO_CHUNK, chunk)
  })
  
  audioService.on('error', (error) => {
    mainWindow.webContents.send(IpcChannels.AUDIO_ERROR, error.message)
  })
}
