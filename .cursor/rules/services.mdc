### Service Implementation
**File:** `src/main/services/ExportService.ts`

```typescript
import fs from 'fs'
import path from 'path'
import type { Recording, TranscriptSegment, RecordingSummary } from '@shared/types'

export class ExportService {
  /**
   * Export recording as Obsidian markdown
   */
  async exportToObsidian(
    recording: Recording,
    segments: TranscriptSegment[],
    summary: RecordingSummary | null,
    options: {
      vaultPath: string
      includeTranscript?: boolean
      includeSummary?: boolean
      template?: string
    }
  ): Promise<string> {
    const fileName = `${recording.title.replace(/[/\\?%*:|"<>]/g, '-')}.md`
    const outputPath = path.join(options.vaultPath, fileName)
    
    // ✅ Build YAML frontmatter
    const frontmatter = [
      '---',
      `title: "${recording.title}"`,
      `date: ${new Date(recording.createdAt).toISOString()}`,
      `category: ${recording.category || 'uncategorized'}`,
      `duration: ${recording.duration}`,
      `tags: [recording, ${recording.category || 'uncategorized'}]`,
      `speakers: [${[...new Set(segments.map(s => s.speaker).filter(Boolean))].join(', ')}]`,
      '---',
      ''
    ].join('\n')
    
    // ✅ Build summary section
    let summarySection = ''
    if (options.includeSummary !== false && summary) {
      summarySection = [
        '## Summary',
        '',
        summary.summary,
        '',
        '### Action Items',
        '',
        ...(summary.action_items || []).map(item => `- [ ] ${item.task} (${item.assignee || 'Unassigned'})`),
        '',
        '### Discussion Points',
        '',
        ...(summary.discussion_points || []).map(point => `- ${point}`),
        '',
        '### Decisions',
        '',
        ...(summary.decisions || []).map(decision => `- ${decision}`),
        ''
      ].join('\n')
    }
    
    // ✅ Build transcript section
    let transcriptSection = ''
    if (options.includeTranscript !== false) {
      transcriptSection = [
        '## Transcript',
        '',
        ...segments.map(seg => {
          const timestamp = this.formatTimestamp(seg.startTime)
          const speaker = seg.speaker || 'Unknown'
          return `**[${timestamp}] ${speaker}:** ${seg.text}`
        }),
        ''
      ].join('\n')
    }
    
    // ✅ Combine sections
    const content = [
      frontmatter,
      summarySection,
      transcriptSection
    ].join('\n')
    
    // Write file
    await fs.promises.writeFile(outputPath, content, 'utf-8')
    
    console.log('[ExportService] Exported to Obsidian:', outputPath)
    return outputPath
  }
  
  /**
   * Export recording as PDF
   */
  async exportToPDF(
    recording: Recording,
    segments: TranscriptSegment[],
    summary: RecordingSummary | null,
    outputPath: string
  ): Promise<string> {
    // TODO: Implement PDF generation (e.g., using PDFKit or Puppeteer)
    throw new Error('PDF export not yet implemented')
  }
  
  /**
   * Format timestamp (seconds → HH:MM:SS)
   */
  private formatTimestamp(seconds: number): string {
    const h = Math.floor(seconds / 3600)
    const m = Math.floor((seconds % 3600) / 60)
    const s = Math.floor(seconds % 60)
    
    return [h, m, s]
      .map(n => n.toString().padStart(2, '0'))
      .join(':')
  }
}
