## 5. DatabaseService (better-sqlite3 schema & migrations)

### Responsibilities
- SQLite database initialization
- Schema migrations
- CRUD operations for recordings, transcripts, summaries
- Full-text search (FTS5)

### Service Implementation
**File:** `src/main/services/DatabaseService.ts`

```typescript
import Database from 'better-sqlite3'
import { app } from 'electron'
import path from 'path'
import fs from 'fs'
import type { Recording, TranscriptSegment, RecordingSummary } from '@shared/types'

export class DatabaseService {
  private db: Database.Database
  
  constructor() {
    const dbPath = path.join(app.getPath('userData'), 'voicevault.db')
    console.log('[DatabaseService] Opening database:', dbPath)
    
    this.db = new Database(dbPath)
    this.initialize()
  }
  
  /**
   * Initialize database schema
   */
  private initialize(): void {
    // ✅ Enable WAL mode for better concurrency
    this.db.pragma('journal_mode = WAL')
    this.db.pragma('foreign_keys = ON')
    
    // Create tables
    this.db.exec(`
      CREATE TABLE IF NOT EXISTS recordings (
        id TEXT PRIMARY KEY,
        title TEXT NOT NULL,
        audioPath TEXT NOT NULL,
        duration INTEGER NOT NULL,
        createdAt INTEGER NOT NULL,
        category TEXT,
        language TEXT DEFAULT 'auto',
        metadata TEXT
      );
      
      CREATE TABLE IF NOT EXISTS transcript_segments (
        id TEXT PRIMARY KEY,
        recordingId TEXT NOT NULL,
        text TEXT NOT NULL,
        startTime REAL NOT NULL,
        endTime REAL NOT NULL,
        speaker TEXT,
        FOREIGN KEY (recordingId) REFERENCES recordings(id) ON DELETE CASCADE
      );
      
      CREATE TABLE IF NOT EXISTS summaries (
        id TEXT PRIMARY KEY,
        recordingId TEXT NOT NULL UNIQUE,
        summary TEXT NOT NULL,
        actionItems TEXT,
        discussionPoints TEXT,
        keyStatements TEXT,
        decisions TEXT,
        createdAt INTEGER NOT NULL,
        FOREIGN KEY (recordingId) REFERENCES recordings(id) ON DELETE CASCADE
      );
      
      CREATE TABLE IF NOT EXISTS speaker_profiles (
        id TEXT PRIMARY KEY,
        name TEXT NOT NULL,
        embedding BLOB,
        createdAt INTEGER NOT NULL,
        updatedAt INTEGER NOT NULL
      );
      
      -- ✅ Full-text search indices
      CREATE VIRTUAL TABLE IF NOT EXISTS transcript_fts USING fts5(
        recordingId,
        text,
        content='transcript_segments',
        content_rowid='rowid'
      );
      
      -- Triggers to keep FTS index in sync
      CREATE TRIGGER IF NOT EXISTS transcript_ai AFTER INSERT ON transcript_segments BEGIN
        INSERT INTO transcript_fts(rowid, recordingId, text)
        VALUES (new.rowid, new.recordingId, new.text);
      END;
      
      CREATE TRIGGER IF NOT EXISTS transcript_ad AFTER DELETE ON transcript_segments BEGIN
        DELETE FROM transcript_fts WHERE rowid = old.rowid;
      END;
      
      CREATE TRIGGER IF NOT EXISTS transcript_au AFTER UPDATE ON transcript_segments BEGIN
        UPDATE transcript_fts SET text = new.text WHERE rowid = new.rowid;
      END;
    `)
    
    // Create indices
    this.db.exec(`
      CREATE INDEX IF NOT EXISTS idx_segments_recording ON transcript_segments(recordingId);
      CREATE INDEX IF NOT EXISTS idx_recordings_created ON recordings(createdAt DESC);
      CREATE INDEX IF NOT EXISTS idx_recordings_category ON recordings(category);
    `)
    
    console.log('[DatabaseService] Database initialized')
  }
  
  /**
   * Insert new recording
   */
  insertRecording(recording: Recording): void {
    const stmt = this.db.prepare(`
      INSERT INTO recordings (id, title, audioPath, duration, createdAt, category, language, metadata)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    `)
    
    stmt.run(
      recording.id,
      recording.title,
      recording.audioPath,
      recording.duration,
      recording.createdAt,
      recording.category || null,
      recording.language || 'auto',
      JSON.stringify(recording.metadata || {})
    )
  }
  
  /**
   * Get all recordings
   */
  getRecordings(filters?: {
    category?: string
    startDate?: number
    endDate?: number
  }): Recording[] {
    let query = 'SELECT * FROM recordings WHERE 1=1'
    const params: any[] = []
    
    if (filters?.category) {
      query += ' AND category = ?'
      params.push(filters.category)
    }
    if (filters?.startDate) {
      query += ' AND createdAt >= ?'
      params.push(filters.startDate)
    }
    if (filters?.endDate) {
      query += ' AND createdAt <= ?'
      params.push(filters.endDate)
    }
    
    query += ' ORDER BY createdAt DESC'
    
    const stmt = this.db.prepare(query)
    const rows = stmt.all(...params) as any[]
    
    return rows.map(row => ({
      ...row,
      metadata: JSON.parse(row.metadata || '{}')
    }))
  }
  
  /**
   * Get recording by ID
   */
  getRecording(id: string): Recording | null {
    const stmt = this.db.prepare('SELECT * FROM recordings WHERE id = ?')
    const row = stmt.get(id) as any
    
    if (!row) return null
    
    return {
      ...row,
      metadata: JSON.parse(row.metadata || '{}')
    }
  }
  
  /**
   * Insert transcript segments (bulk)
   */
  insertTranscriptSegments(segments: TranscriptSegment[]): void {
    const insert = this.db.prepare(`
      INSERT INTO transcript_segments (id, recordingId, text, startTime, endTime, speaker)
      VALUES (?, ?, ?, ?, ?, ?)
    `)
    
    // ✅ Use transaction for bulk insert (10-100x faster)
    const insertMany = this.db.transaction((segments: TranscriptSegment[]) => {
      for (const seg of segments) {
        insert.run(seg.id, seg.recordingId, seg.text, seg.startTime, seg.endTime, seg.speaker)
      }
    })
    
    insertMany(segments)
  }
  
  /**
   * Get transcript segments for recording
   */
  getTranscriptSegments(recordingId: string): TranscriptSegment[] {
    const stmt = this.db.prepare(`
      SELECT * FROM transcript_segments 
      WHERE recordingId = ? 
      ORDER BY startTime ASC
    `)
    return stmt.all(recordingId) as TranscriptSegment[]
  }
  
  /**
   * Insert or update summary
   */
  upsertSummary(recordingId: string, summary: RecordingSummary): void {
    const stmt = this.db.prepare(`
      INSERT INTO summaries (id, recordingId, summary, actionItems, discussionPoints, keyStatements, decisions, createdAt)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?)
      ON CONFLICT(recordingId) DO UPDATE SET
        summary = excluded.summary,
        actionItems = excluded.actionItems,
        discussionPoints = excluded.discussionPoints,
        keyStatements = excluded.keyStatements,
        decisions = excluded.decisions
    `)
    
    stmt.run(
      `summary-${recordingId}`,
      recordingId,
      summary.summary,
      JSON.stringify(summary.action_items || []),
      JSON.stringify(summary.discussion_points || []),
      JSON.stringify(summary.key_statements || []),
      JSON.stringify(summary.decisions || []),
      Date.now()
    )
  }
  
  /**
   * Full-text search across transcripts
   */
  searchTranscripts(query: string, limit = 50): Array<{
    recordingId: string
    text: string
    snippet: string
  }> {
    const stmt = this.db.prepare(`
      SELECT 
        recordingId,
        text,
        snippet(transcript_fts, 1, '<mark>', '</mark>', '...', 32) as snippet
      FROM transcript_fts
      WHERE transcript_fts MATCH ?
      ORDER BY rank
      LIMIT ?
    `)
    
    return stmt.all(query, limit) as any[]
  }
  
  /**
   * Delete recording and all associated data
   */
  deleteRecording(id: string): void {
    // ✅ Foreign key cascade will delete segments and summaries
    const stmt = this.db.prepare('DELETE FROM recordings WHERE id = ?')
    stmt.run(id)
    
    // Also delete audio file
    const recording = this.getRecording(id)
    if (recording && fs.existsSync(recording.audioPath)) {
      fs.unlinkSync(recording.audioPath)
    }
  }
  
  /**
   * Cleanup resources
   */
  cleanup(): void {
    this.db.close()
  }
}
```

