## Streaming Patterns (Real-Time Transcription)

### The Challenge
Whisper models process entire audio files, not real-time streams. To get "live" transcription:

1. **Buffer audio chunks** (e.g., 30-second windows)
2. **Transcribe each chunk** as it completes
3. **Stream results to renderer** segment-by-segment
4. **Merge overlapping segments** to avoid duplicates

### Implementation
```typescript
class WhisperService {
  private chunkBuffer: Buffer[] = []
  private chunkDuration = 30  // seconds
  
  async startStreamingTranscription(audioStream: EventEmitter): Promise<void> {
    audioStream.on('data', async (chunk: Buffer) => {
      this.chunkBuffer.push(chunk)
      
      // Check if we have enough for a chunk
      const totalDuration = this.chunkBuffer.length * 0.1  // Assuming 100ms per chunk
      
      if (totalDuration >= this.chunkDuration) {
        // Transcribe accumulated chunk
        const audioData = Buffer.concat(this.chunkBuffer)
        await this.transcribeChunk(audioData)
        
        // Clear buffer (with 5s overlap for continuity)
        this.chunkBuffer = this.chunkBuffer.slice(-50)  // Keep last 5 seconds
      }
    })
  }
  
  private async transcribeChunk(audioData: Buffer): Promise<void> {
    // Write temporary file
    const tempPath = `/tmp/chunk-${Date.now()}.wav`
    await fs.promises.writeFile(tempPath, audioData)
    
    // Transcribe
    await this.model!.transcribe(tempPath, {
      onSegment: (segment) => {
        this.emit('segment', segment)
      }
    })
    
    // Clean up
    fs.unlinkSync(tempPath)
  }
}
```

