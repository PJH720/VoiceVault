## 4. LLMService (node-llama-cpp + optional Claude API)

### Responsibilities
- Load local GGUF models (Llama 3.2 3B, Gemma-3n, etc.)
- Generate structured summaries from transcripts
- Extract action items, discussion points, key statements
- Optional Claude API fallback for higher quality

### Dependencies
```json
{
  "node-llama-cpp": "^3.0.0",
  "@anthropic-ai/sdk": "^0.27.0"  // Optional
}
```

### Service Implementation
**File:** `src/main/services/LLMService.ts`

```typescript
import { EventEmitter } from 'events'
import path from 'path'
import { app } from 'electron'
import { LlamaModel, LlamaContext, LlamaChatSession } from 'node-llama-cpp'
import Anthropic from '@anthropic-ai/sdk'
import type { RecordingSummary, TranscriptSegment } from '@shared/types'

export class LLMService extends EventEmitter {
  private model: LlamaModel | null = null
  private context: LlamaContext | null = null
  private anthropic: Anthropic | null = null
  
  constructor() {
    super()
    
    // ✅ Initialize Claude API if key is available
    if (process.env.ANTHROPIC_API_KEY) {
      this.anthropic = new Anthropic({
        apiKey: process.env.ANTHROPIC_API_KEY
      })
    }
  }
  
  /**
   * Initialize local GGUF model
   */
  async initialize(modelName: string): Promise<void> {
    const modelsDir = path.join(app.getPath('userData'), 'models')
    const modelPath = path.join(modelsDir, modelName)
    
    console.log('[LLMService] Loading model:', modelPath)
    
    // ✅ Load GGUF model
    this.model = await LlamaModel.load(modelPath, {
      gpuLayers: 33,  // Offload layers to GPU (Metal on macOS)
      contextSize: 4096
    })
    
    this.context = await this.model.createContext({
      contextSize: 4096
    })
    
    console.log('[LLMService] Model loaded')
  }
  
  /**
   * Generate structured summary from transcript
   */
  async summarize(
    segments: TranscriptSegment[],
    useClaudeAPI = false
  ): Promise<RecordingSummary> {
    // Concatenate transcript text
    const fullTranscript = segments
      .map(s => `[${s.speaker || 'Unknown'}] ${s.text}`)
      .join('\n')
    
    const prompt = this.buildSummaryPrompt(fullTranscript)
    
    if (useClaudeAPI && this.anthropic) {
      return this.summarizeWithClaude(prompt)
    } else {
      return this.summarizeLocally(prompt)
    }
  }
  
  /**
   * Build prompt for summarization
   */
  private buildSummaryPrompt(transcript: string): string {
    return `You are an AI assistant that creates structured summaries of voice recordings.

Given the following transcript, extract:
1. A concise summary (2-3 sentences)
2. Action items (if any)
3. Key discussion points
4. Important statements with speaker attribution
5. Decisions made

Transcript:
${transcript}

Respond in JSON format:
{
  "summary": "...",
  "action_items": [{"task": "...", "assignee": "...", "deadline": "..."}],
  "discussion_points": ["...", "..."],
  "key_statements": [{"speaker": "...", "text": "...", "timestamp": "..."}],
  "decisions": ["...", "..."]
}

JSON:`
  }
  
  /**
   * Summarize using local model
   */
  private async summarizeLocally(prompt: string): Promise<RecordingSummary> {
    if (!this.model || !this.context) {
      throw new Error('LLM model not initialized')
    }
    
    console.log('[LLMService] Generating summary (local)...')
    
    const session = new LlamaChatSession({
      contextSequence: this.context.getSequence()
    })
    
    // ✅ Stream tokens to renderer
    let fullResponse = ''
    
    await session.prompt(prompt, {
      onTextChunk: (chunk: string) => {
        fullResponse += chunk
        this.emit('token', chunk)
      },
      maxTokens: 1024,
      temperature: 0.7
    })
    
    // Parse JSON response
    try {
      const jsonMatch = fullResponse.match(/\{[\s\S]*\}/)
      if (!jsonMatch) {
        throw new Error('No JSON found in response')
      }
      
      const summary: RecordingSummary = JSON.parse(jsonMatch[0])
      console.log('[LLMService] Summary generated (local)')
      return summary
    } catch (error) {
      console.error('[LLMService] JSON parse failed:', error)
      throw new Error('Failed to parse LLM response')
    }
  }
  
  /**
   * Summarize using Claude API
   */
  private async summarizeWithClaude(prompt: string): Promise<RecordingSummary> {
    if (!this.anthropic) {
      throw new Error('Claude API not configured')
    }
    
    console.log('[LLMService] Generating summary (Claude API)...')
    
    const message = await this.anthropic.messages.create({
      model: 'claude-3-5-sonnet-20241022',
      max_tokens: 2048,
      messages: [{
        role: 'user',
        content: prompt
      }]
    })
    
    const response = message.content[0].text
    
    // Parse JSON response
    const jsonMatch = response.match(/\{[\s\S]*\}/)
    if (!jsonMatch) {
      throw new Error('No JSON found in Claude response')
    }
    
    const summary: RecordingSummary = JSON.parse(jsonMatch[0])
    console.log('[LLMService] Summary generated (Claude API)')
    return summary
  }
  
  /**
   * Cleanup resources
   */
  cleanup(): void {
    if (this.context) {
      this.context.dispose()
      this.context = null
    }
    if (this.model) {
      this.model.dispose()
      this.model = null
    }
    this.removeAllListeners()
  }
}
```

