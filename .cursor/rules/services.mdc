## 2. WhisperService (whisper-cpp-node with CoreML)

### Responsibilities
- Load Whisper GGML models (base, small, medium, large-v3-turbo)
- Transcribe audio files to text
- Stream transcript segments in real-time
- Speaker diarization integration (post-processing)

### Dependencies
```json
{
  "whisper-cpp-node": "^2.0.0"  // whisper.cpp bindings with CoreML support
}
```

### Service Implementation
**File:** `src/main/services/WhisperService.ts`

```typescript
import { EventEmitter } from 'events'
import path from 'path'
import { app } from 'electron'
import WhisperCpp from 'whisper-cpp-node'
import fs from 'fs'
import type { TranscriptSegment, WhisperConfig } from '@shared/types'

export class WhisperService extends EventEmitter {
  private model: WhisperCpp.Model | null = null
  private currentJobId: string | null = null
  private modelPath: string | null = null
  
  constructor() {
    super()
  }
  
  /**
   * Initialize Whisper service with specified model
   */
  async initialize(modelName: string): Promise<void> {
    const modelsDir = path.join(app.getPath('userData'), 'models')
    this.modelPath = path.join(modelsDir, `ggml-${modelName}.bin`)
    
    // Check if model exists, download if not
    if (!fs.existsSync(this.modelPath)) {
      throw new Error(`Model not found: ${modelName}. Please download it first.`)
    }
    
    console.log('[WhisperService] Loading model:', this.modelPath)
    
    // ✅ Load model with CoreML acceleration on macOS
    this.model = await WhisperCpp.loadModel(this.modelPath, {
      useCoreML: process.platform === 'darwin',  // Enable CoreML on macOS
      useGPU: true,
      numThreads: 4
    })
    
    console.log('[WhisperService] Model loaded successfully')
  }
  
  /**
   * Transcribe audio file
   */
  async transcribe(
    audioPath: string,
    config?: WhisperConfig
  ): Promise<string> {
    if (!this.model) {
      throw new Error('Whisper model not initialized')
    }
    
    // Validate audio file exists
    if (!fs.existsSync(audioPath)) {
      throw new Error(`Audio file not found: ${audioPath}`)
    }
    
    const jobId = `whisper-${Date.now()}`
    this.currentJobId = jobId
    
    console.log('[WhisperService] Starting transcription:', { jobId, audioPath })
    
    // ✅ Streaming transcription
    const segments: TranscriptSegment[] = []
    
    await this.model.transcribe(audioPath, {
      language: config?.language || 'auto',
      translate: config?.translate || false,
      maxLen: 1,  // Single token inference for streaming
      onSegment: (segment) => {
        // Map whisper.cpp segment to our TranscriptSegment type
        const transcriptSegment: TranscriptSegment = {
          id: `${jobId}-${segment.index}`,
          recordingId: '',  // Set by caller
          text: segment.text.trim(),
          startTime: segment.t0 / 100,  // Convert to seconds
          endTime: segment.t1 / 100,
          speaker: null  // Filled in by DiarizationService
        }
        
        segments.push(transcriptSegment)
        
        // ✅ Emit segment to IPC handler (streaming to renderer)
        this.emit('segment', transcriptSegment)
      }
    })
    
    console.log('[WhisperService] Transcription complete:', {
      jobId,
      segmentCount: segments.length
    })
    
    this.currentJobId = null
    return jobId
  }
  
  /**
   * Cancel active transcription
   */
  cancelTranscription(): void {
    if (this.currentJobId) {
      // whisper-cpp-node doesn't support cancellation yet
      // Just reset state
      this.currentJobId = null
      console.log('[WhisperService] Transcription cancelled')
    }
  }
  
  /**
   * Get available models
   */
  getAvailableModels(): string[] {
    const modelsDir = path.join(app.getPath('userData'), 'models')
    if (!fs.existsSync(modelsDir)) return []
    
    return fs.readdirSync(modelsDir)
      .filter(file => file.startsWith('ggml-') && file.endsWith('.bin'))
      .map(file => file.replace('ggml-', '').replace('.bin', ''))
  }
  
  /**
   * Download Whisper model
   */
  async downloadModel(modelName: string): Promise<void> {
    const modelsDir = path.join(app.getPath('userData'), 'models')
    await fs.promises.mkdir(modelsDir, { recursive: true })
    
    const modelUrl = `https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-${modelName}.bin`
    const outputPath = path.join(modelsDir, `ggml-${modelName}.bin`)
    
    console.log('[WhisperService] Downloading model:', { modelName, url: modelUrl })
    
    // ✅ Stream download with progress
    const response = await fetch(modelUrl)
    if (!response.ok) {
      throw new Error(`Model download failed: ${response.statusText}`)
    }
    
    const totalSize = parseInt(response.headers.get('content-length') || '0', 10)
    let downloadedSize = 0
    
    const writer = fs.createWriteStream(outputPath)
    const reader = response.body!.getReader()
    
    while (true) {
      const { done, value } = await reader.read()
      if (done) break
      
      writer.write(value)
      downloadedSize += value.length
      
      const progress = (downloadedSize / totalSize) * 100
      this.emit('download-progress', { modelName, progress, downloadedSize, totalSize })
    }
    
    writer.end()
    console.log('[WhisperService] Model downloaded:', outputPath)
  }
  
  /**
   * Cleanup resources
   */
  cleanup(): void {
    if (this.model) {
      // Unload model to free memory
      this.model = null
    }
    this.removeAllListeners()
  }
}
```

### IPC Handler
**File:** `src/main/ipc/transcription.ts`

```typescript
import { ipcMain, BrowserWindow } from 'electron'
import { IpcChannels } from '@shared/ipc-channels'
import { WhisperService } from '@main/services/WhisperService'

export function registerTranscriptionHandlers(
  whisperService: WhisperService,
  mainWindow: BrowserWindow
): void {
  // Get available models
  ipcMain.handle(IpcChannels.WHISPER_GET_MODELS, () => {
    return whisperService.getAvailableModels()
  })
  
  // Download model
  ipcMain.handle(IpcChannels.WHISPER_DOWNLOAD_MODEL, async (event, modelName: string) => {
    await whisperService.downloadModel(modelName)
  })
  
  // Initialize model
  ipcMain.handle(IpcChannels.WHISPER_INIT, async (event, modelName: string) => {
    await whisperService.initialize(modelName)
  })
  
  // Transcribe audio
  ipcMain.handle(IpcChannels.WHISPER_TRANSCRIBE, async (event, audioPath: string, config) => {
    const jobId = await whisperService.transcribe(audioPath, config)
    return jobId
  })
  
  // Cancel transcription
  ipcMain.handle(IpcChannels.WHISPER_CANCEL, () => {
    whisperService.cancelTranscription()
  })
  
  // ✅ Stream segments to renderer
  whisperService.on('segment', (segment) => {
    mainWindow.webContents.send(IpcChannels.WHISPER_CHUNK, segment)
  })
  
  // Stream download progress
  whisperService.on('download-progress', (progress) => {
    mainWindow.webContents.send(IpcChannels.WHISPER_DOWNLOAD_PROGRESS, progress)
  })
}
```

