## 3. DiarizationService (pyannote-cpp-node)

### Responsibilities
- Speaker segmentation (who spoke when)
- Speaker embeddings (voice fingerprints)
- Speaker clustering (group segments by speaker)
- Label transcript segments with speaker IDs

### Dependencies
```json
{
  "pyannote-cpp-node": "^1.0.0"  // pyannote-ggml bindings
}
```

### Service Implementation
**File:** `src/main/services/DiarizationService.ts`

```typescript
import { EventEmitter } from 'events'
import path from 'path'
import { app } from 'electron'
import PyannoteNode from 'pyannote-cpp-node'
import type { DiarizationSegment, TranscriptSegment } from '@shared/types'

export class DiarizationService extends EventEmitter {
  private model: PyannoteNode.Pipeline | null = null
  private modelPath: string | null = null
  
  constructor() {
    super()
  }
  
  /**
   * Initialize diarization pipeline
   */
  async initialize(): Promise<void> {
    const modelsDir = path.join(app.getPath('userData'), 'models')
    this.modelPath = path.join(modelsDir, 'pyannote-segmentation-3.0.gguf')
    
    console.log('[DiarizationService] Loading model:', this.modelPath)
    
    this.model = await PyannoteNode.loadPipeline(this.modelPath, {
      useGPU: false,  // CPU inference (fast enough)
      numThreads: 4
    })
    
    console.log('[DiarizationService] Model loaded')
  }
  
  /**
   * Run diarization on audio file
   */
  async diarize(audioPath: string): Promise<DiarizationSegment[]> {
    if (!this.model) {
      throw new Error('Diarization model not initialized')
    }
    
    console.log('[DiarizationService] Processing:', audioPath)
    
    // ✅ Run diarization pipeline
    const result = await this.model.process(audioPath)
    
    // Map pyannote output to our DiarizationSegment format
    const segments: DiarizationSegment[] = result.turns.map((turn, index) => ({
      startTime: turn.start,
      endTime: turn.end,
      speaker: `speaker_${turn.speaker}`
    }))
    
    console.log('[DiarizationService] Diarization complete:', {
      segmentCount: segments.length,
      speakers: new Set(segments.map(s => s.speaker)).size
    })
    
    return segments
  }
  
  /**
   * Align diarization segments with transcript segments
   */
  alignWithTranscript(
    transcriptSegments: TranscriptSegment[],
    diarizationSegments: DiarizationSegment[]
  ): TranscriptSegment[] {
    // ✅ For each transcript segment, find overlapping diarization segment
    return transcriptSegments.map(segment => {
      const midpoint = (segment.startTime + segment.endTime) / 2
      
      // Find diarization segment that contains midpoint
      const diarizationSegment = diarizationSegments.find(
        d => d.startTime <= midpoint && midpoint <= d.endTime
      )
      
      return {
        ...segment,
        speaker: diarizationSegment?.speaker || null
      }
    })
  }
  
  /**
   * Cleanup resources
   */
  cleanup(): void {
    if (this.model) {
      this.model = null
    }
    this.removeAllListeners()
  }
}
```

