## Forbidden Patterns

### тЭМ Never Do This
```typescript
// 1. Direct Node.js APIs in renderer
import fs from 'fs'  // тЭМ NEVER in renderer process

// 2. Hardcoded strings
<button>Start Recording</button>  // тЭМ Use t('recording.controls.start')

// 3. `any` type
function process(data: any) { ... }  // тЭМ Use proper types or `unknown`

// 4. Direct ipcRenderer in renderer
import { ipcRenderer } from 'electron'  // тЭМ Use window.api.* instead

// 5. Inline styles
<div style={{ color: 'red' }}>  // тЭМ Use Tailwind classes

// 6. Class components
class MyComponent extends React.Component { ... }  // тЭМ Use function components

// 7. Unvalidated IPC inputs
ipcMain.handle('delete-file', (_, path) => {
  fs.unlinkSync(path)  // тЭМ No validation = security hole
})
```

### тЬЕ Do This Instead
```typescript
// 1. Use IPC through preload
window.api.readFile(path)  // тЬЕ Exposed via contextBridge

// 2. Use translations
<button>{t('recording.controls.start')}</button>  // тЬЕ

// 3. Use proper types
function process(data: RecordingData) { ... }  // тЬЕ

// 4. Use exposed API
window.api.transcribe(audioData)  // тЬЕ

// 5. Use Tailwind
<div className="text-red-500">  // тЬЕ

// 6. Function components
function MyComponent() { ... }  // тЬЕ

// 7. Validate IPC inputs
ipcMain.handle('delete-file', (_, path: string) => {
  if (!isValidPath(path)) throw new Error('Invalid path')
  if (!path.startsWith(app.getPath('userData'))) throw new Error('Unauthorized')
  fs.unlinkSync(path)  // тЬЕ
})
```

