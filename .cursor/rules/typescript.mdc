## better-sqlite3 Patterns

### Database Service
**File:** `src/main/services/DatabaseService.ts`
```typescript
import Database from 'better-sqlite3'
import { app } from 'electron'
import path from 'path'
import type { Recording, TranscriptSegment } from '@shared/types'

export class DatabaseService {
  private db: Database.Database
  
  constructor() {
    const dbPath = path.join(app.getPath('userData'), 'voicevault.db')
    this.db = new Database(dbPath)
    this.initialize()
  }
  
  private initialize(): void {
    // ✅ Enable WAL mode for better concurrency
    this.db.pragma('journal_mode = WAL')
    
    // ✅ Create tables
    this.db.exec(`
      CREATE TABLE IF NOT EXISTS recordings (
        id TEXT PRIMARY KEY,
        title TEXT NOT NULL,
        audioPath TEXT NOT NULL,
        duration INTEGER NOT NULL,
        createdAt INTEGER NOT NULL,
        category TEXT,
        metadata TEXT
      );
      
      CREATE TABLE IF NOT EXISTS transcript_segments (
        id TEXT PRIMARY KEY,
        recordingId TEXT NOT NULL,
        text TEXT NOT NULL,
        startTime REAL NOT NULL,
        endTime REAL NOT NULL,
        speaker TEXT,
        FOREIGN KEY (recordingId) REFERENCES recordings(id) ON DELETE CASCADE
      );
      
      CREATE INDEX IF NOT EXISTS idx_segments_recording 
        ON transcript_segments(recordingId);
    `)
  }
  
  // ✅ Prepared statements for performance
  getRecordings(): Recording[] {
    const stmt = this.db.prepare(`
      SELECT * FROM recordings 
      ORDER BY createdAt DESC
    `)
    return stmt.all() as Recording[]
  }
  
  insertRecording(recording: Recording): void {
    const stmt = this.db.prepare(`
      INSERT INTO recordings (id, title, audioPath, duration, createdAt, category, metadata)
      VALUES (?, ?, ?, ?, ?, ?, ?)
    `)
    stmt.run(
      recording.id,
      recording.title,
      recording.audioPath,
      recording.duration,
      recording.createdAt,
      recording.category,
      JSON.stringify(recording.metadata)
    )
  }
  
  // ✅ Transaction for bulk inserts
  insertTranscriptSegments(segments: TranscriptSegment[]): void {
    const insert = this.db.prepare(`
      INSERT INTO transcript_segments (id, recordingId, text, startTime, endTime, speaker)
      VALUES (?, ?, ?, ?, ?, ?)
    `)
    
    const insertMany = this.db.transaction((segments: TranscriptSegment[]) => {
      for (const seg of segments) {
        insert.run(seg.id, seg.recordingId, seg.text, seg.startTime, seg.endTime, seg.speaker)
      }
    })
    
    insertMany(segments)
  }
  
  close(): void {
    this.db.close()
  }
}
```

