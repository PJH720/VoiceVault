## IPC Bridge Rules (Critical)

### The Three-Process Architecture
```
┌─────────────────────────────────────────────────────────────┐
│                      Renderer Process                        │
│                   (React + UI, Chromium)                     │
│  - NO Node.js APIs                                           │
│  - NO direct ipcRenderer                                     │
│  - ONLY window.api.* (exposed by preload)                    │
└───────────────────────────┬─────────────────────────────────┘
                            │ IPC
                            │ (type-safe, validated)
┌───────────────────────────▼─────────────────────────────────┐
│                      Preload Script                          │
│                   (contextBridge API)                        │
│  - Exposes typed API to renderer                             │
│  - Acts as security boundary                                 │
│  - NO business logic                                         │
└───────────────────────────┬─────────────────────────────────┘
                            │ ipcRenderer.invoke()
┌───────────────────────────▼─────────────────────────────────┐
│                      Main Process                            │
│                   (Node.js + Native Addons)                  │
│  - All heavy compute here                                    │
│  - Native modules (whisper-cpp-node, better-sqlite3)         │
│  - File system, database, AI services                        │
└─────────────────────────────────────────────────────────────┘
```

### Preload Script Pattern
**File:** `src/preload/index.ts`
```typescript
import { contextBridge, ipcRenderer } from 'electron'
import type { IpcChannels } from '@shared/ipc-channels'

// Define the API surface exposed to renderer
export type API = {
  // Audio capture
  startAudioCapture: (deviceId: string) => Promise<void>
  stopAudioCapture: () => Promise<string>  // Returns audioPath
  
  // Transcription
  transcribe: (audioPath: string) => Promise<string>  // Returns jobId
  onTranscriptChunk: (callback: (chunk: TranscriptSegment) => void) => () => void
  
  // Database
  getRecordings: (filters?: RecordingFilters) => Promise<Recording[]>
  deleteRecording: (id: string) => Promise<void>
  
  // Settings
  getSettings: () => Promise<AppSettings>
  updateSettings: (settings: Partial<AppSettings>) => Promise<void>
}

// ✅ Expose typed API via contextBridge
contextBridge.exposeInMainWorld('api', {
  startAudioCapture: (deviceId: string) => 
    ipcRenderer.invoke(IpcChannels.AUDIO_START, deviceId),
  
  stopAudioCapture: () => 
    ipcRenderer.invoke(IpcChannels.AUDIO_STOP),
  
  transcribe: (audioPath: string) => 
    ipcRenderer.invoke(IpcChannels.WHISPER_TRANSCRIBE, audioPath),
  
  onTranscriptChunk: (callback) => {
    const listener = (_: unknown, chunk: TranscriptSegment) => callback(chunk)
    ipcRenderer.on(IpcChannels.WHISPER_CHUNK, listener)
    
    // Return cleanup function
    return () => ipcRenderer.removeListener(IpcChannels.WHISPER_CHUNK, listener)
  },
  
  // ... rest of API
} satisfies API)

// Type augmentation for window object
declare global {
  interface Window {
    api: API
  }
}
```

### IPC Channel Definitions
**File:** `src/shared/ipc-channels.ts`
```typescript
// ✅ All IPC channels defined as constants
export const IpcChannels = {
  // Audio
  AUDIO_START: 'audio:start-capture',
  AUDIO_STOP: 'audio:stop-capture',
  AUDIO_CHUNK: 'audio:chunk',  // main → renderer (streaming)
  
  // Whisper transcription
  WHISPER_TRANSCRIBE: 'whisper:transcribe',
  WHISPER_CHUNK: 'whisper:chunk',  // main → renderer (streaming)
  WHISPER_COMPLETE: 'whisper:complete',
  
  // LLM summarization
  LLM_SUMMARIZE: 'llm:summarize',
  LLM_STREAM: 'llm:stream',  // main → renderer (streaming)
  
  // Database
  DB_GET_RECORDINGS: 'db:get-recordings',
  DB_DELETE_RECORDING: 'db:delete-recording',
  DB_SEARCH: 'db:search',
  
  // Export
  EXPORT_OBSIDIAN: 'export:obsidian',
  EXPORT_PDF: 'export:pdf',
  
  // Settings
  SETTINGS_GET: 'settings:get',
  SETTINGS_UPDATE: 'settings:update',
} as const

export type IpcChannel = typeof IpcChannels[keyof typeof IpcChannels]
```

### IPC Handler Pattern (Main Process)
**File:** `src/main/ipc/transcription.ts`
```typescript
import { ipcMain } from 'electron'
import { IpcChannels } from '@shared/ipc-channels'
import { WhisperService } from '@main/services/WhisperService'

// ✅ Initialize IPC handlers
export function registerTranscriptionHandlers(whisperService: WhisperService): void {
  // Request-response pattern
  ipcMain.handle(IpcChannels.WHISPER_TRANSCRIBE, async (event, audioPath: string) => {
    // ✅ Validate input
    if (typeof audioPath !== 'string') {
      throw new Error('audioPath must be a string')
    }
    if (!audioPath.startsWith(app.getPath('userData'))) {
      throw new Error('Unauthorized path')
    }
    
    const jobId = await whisperService.transcribe(audioPath, {
      onChunk: (chunk) => {
        // ✅ Stream results back to renderer
        event.sender.send(IpcChannels.WHISPER_CHUNK, chunk)
      }
    })
    
    return jobId
  })
}
```

### Renderer Usage Pattern
**File:** `src/renderer/hooks/useTranscription.ts`
```typescript
import { useState, useEffect, useCallback } from 'react'
import type { TranscriptSegment } from '@shared/types'

export function useTranscription(audioPath: string | null) {
  const [segments, setSegments] = useState<TranscriptSegment[]>([])
  const [isTranscribing, setIsTranscribing] = useState(false)
  const [error, setError] = useState<Error | null>(null)
  
  useEffect(() => {
    if (!audioPath) return
    
    setIsTranscribing(true)
    setError(null)
    
    // ✅ Subscribe to streaming chunks
    const cleanup = window.api.onTranscriptChunk((chunk) => {
      setSegments(prev => [...prev, chunk])
    })
    
    // ✅ Start transcription
    window.api.transcribe(audioPath)
      .then((jobId) => {
        console.log('[useTranscription] Job started:', jobId)
      })
      .catch((err) => {
        setError(err)
        setIsTranscribing(false)
      })
    
    // ✅ Cleanup on unmount
    return () => {
      cleanup()
      setIsTranscribing(false)
    }
  }, [audioPath])
  
  return { segments, isTranscribing, error }
}
```

### Forbidden IPC Patterns
```typescript
// ❌ NEVER import ipcRenderer in renderer
import { ipcRenderer } from 'electron'  // ❌ Security hole!

// ❌ NEVER expose entire Node.js APIs
contextBridge.exposeInMainWorld('fs', require('fs'))  // ❌ Massive security hole!

// ❌ NEVER trust renderer input without validation
ipcMain.handle('delete-file', (_, path) => {
  fs.unlinkSync(path)  // ❌ Path traversal attack possible!
})

// ❌ NEVER send sensitive data without scrubbing
ipcMain.handle('get-config', () => {
  return { apiKey: process.env.API_KEY }  // ❌ Leaks secrets to renderer!
})
```

