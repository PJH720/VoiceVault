## React 19 Patterns

### Functional Components Only
**Rule:** No class components. Ever.

```typescript
// ❌ Class component (forbidden)
class RecordingButton extends React.Component {
  render() {
    return <button>Record</button>
  }
}

// ✅ Function component
function RecordingButton() {
  return <button>Record</button>
}

// ✅ Arrow function (acceptable)
const RecordingButton = () => {
  return <button>Record</button>
}

// ✅ Explicit return type (preferred for exported components)
export function RecordingButton(): JSX.Element {
  return <button>Record</button>
}
```

### Component Props Pattern
```typescript
// ✅ Define props interface
interface RecordingControlsProps {
  isRecording: boolean
  onStart: () => void
  onStop: () => void
  disabled?: boolean
}

// ✅ Destructure props with types
export function RecordingControls({
  isRecording,
  onStart,
  onStop,
  disabled = false
}: RecordingControlsProps): JSX.Element {
  return (
    <div>
      {!isRecording ? (
        <button onClick={onStart} disabled={disabled}>Start</button>
      ) : (
        <button onClick={onStop}>Stop</button>
      )}
    </div>
  )
}
```

### Children Prop Typing
```typescript
// ✅ React.ReactNode for flexible children
interface CardProps {
  children: React.ReactNode
  title: string
}

export function Card({ children, title }: CardProps): JSX.Element {
  return (
    <div className="card">
      <h2>{title}</h2>
      {children}
    </div>
  )
}
```

