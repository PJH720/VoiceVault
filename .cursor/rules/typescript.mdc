## React Context Patterns (State Management)

### No Redux / No Zustand
VoiceVault uses **React Context** for state management. Reasons:
- Simple, built-in, no extra dependencies
- Sufficient for our use case (local state, not global cache)
- IPC is the source of truth (main process), renderer is just a view

### Context Pattern
**File:** `src/renderer/contexts/RecordingContext.tsx`
```typescript
import React, { createContext, useContext, useState, useCallback, ReactNode } from 'react'

// ✅ Define context state and actions
interface RecordingContextValue {
  isRecording: boolean
  audioPath: string | null
  startRecording: (deviceId: string) => Promise<void>
  stopRecording: () => Promise<void>
  error: Error | null
}

// ✅ Create context with undefined default (enforces provider usage)
const RecordingContext = createContext<RecordingContextValue | undefined>(undefined)

// ✅ Provider component
interface RecordingProviderProps {
  children: ReactNode
}

export function RecordingProvider({ children }: RecordingProviderProps): JSX.Element {
  const [isRecording, setIsRecording] = useState(false)
  const [audioPath, setAudioPath] = useState<string | null>(null)
  const [error, setError] = useState<Error | null>(null)
  
  const startRecording = useCallback(async (deviceId: string) => {
    try {
      setError(null)
      await window.api.startAudioCapture(deviceId)
      setIsRecording(true)
    } catch (err) {
      setError(err as Error)
      throw err
    }
  }, [])
  
  const stopRecording = useCallback(async () => {
    try {
      const path = await window.api.stopAudioCapture()
      setAudioPath(path)
      setIsRecording(false)
    } catch (err) {
      setError(err as Error)
      throw err
    }
  }, [])
  
  const value = {
    isRecording,
    audioPath,
    startRecording,
    stopRecording,
    error
  }
  
  return (
    <RecordingContext.Provider value={value}>
      {children}
    </RecordingContext.Provider>
  )
}

// ✅ Custom hook for consuming context
export function useRecording(): RecordingContextValue {
  const context = useContext(RecordingContext)
  if (!context) {
    throw new Error('useRecording must be used within RecordingProvider')
  }
  return context
}
```

