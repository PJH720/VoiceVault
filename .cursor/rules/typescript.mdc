## MVVM-like Separation

### Architecture Layers
```
┌─────────────────────────────────────────────┐
│           View (Renderer Process)            │
│  - React components                          │
│  - Presentation logic only                   │
│  - No business logic, no native modules      │
└──────────────────┬──────────────────────────┘
                   │ IPC
┌──────────────────▼──────────────────────────┐
│       ViewModel (Contexts + Hooks)           │
│  - State management (React Context)          │
│  - IPC abstraction (custom hooks)            │
│  - Maps main process data to UI state        │
└──────────────────┬──────────────────────────┘
                   │ IPC
┌──────────────────▼──────────────────────────┐
│         Model (Main Process Services)        │
│  - Business logic, data persistence          │
│  - AudioCaptureService, WhisperService       │
│  - DatabaseService, ExportService            │
└─────────────────────────────────────────────┘
```

### Example: Recording Flow
```typescript
// View (src/renderer/components/Recording/RecordingControls.tsx)
export function RecordingControls() {
  const { isRecording, start, stop } = useRecording()  // ViewModel
  
  return (
    <Button onClick={isRecording ? stop : () => start('default')}>
      {isRecording ? 'Stop' : 'Start'}
    </Button>
  )
}

// ViewModel (src/renderer/hooks/useRecording.ts)
export function useRecording() {
  const [isRecording, setIsRecording] = useState(false)
  
  const start = useCallback(async (deviceId: string) => {
    await window.api.startAudioCapture(deviceId)  // IPC to Model
    setIsRecording(true)
  }, [])
  
  // ...
}

// Model (src/main/services/AudioCaptureService.ts)
export class AudioCaptureService {
  async startCapture(deviceId: string): Promise<void> {
    this.stream = nativeAudio.createInputStream(deviceId)
    // ... native audio capture logic
  }
}
```

