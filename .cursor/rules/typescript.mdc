## Custom Hooks Conventions

### Hook Naming
- **Always prefix with `use`** (e.g., `useTranscription`, `useRecording`)
- **Descriptive names** (e.g., `useDebounce`, `useLocalStorage`, `useAudioWaveform`)

### Hook Pattern
```typescript
// ✅ Custom hook for recording management
export function useRecording() {
  const [isRecording, setIsRecording] = useState(false)
  const [duration, setDuration] = useState(0)
  
  useEffect(() => {
    if (!isRecording) return
    
    const interval = setInterval(() => {
      setDuration(prev => prev + 1)
    }, 1000)
    
    return () => clearInterval(interval)
  }, [isRecording])
  
  const start = useCallback(async (deviceId: string) => {
    await window.api.startAudioCapture(deviceId)
    setIsRecording(true)
    setDuration(0)
  }, [])
  
  const stop = useCallback(async () => {
    const audioPath = await window.api.stopAudioCapture()
    setIsRecording(false)
    return audioPath
  }, [])
  
  return { isRecording, duration, start, stop }
}
```

### Utility Hooks
```typescript
// useDebounce hook
export function useDebounce<T>(value: T, delay: number): T {
  const [debouncedValue, setDebouncedValue] = useState(value)
  
  useEffect(() => {
    const handler = setTimeout(() => {
      setDebouncedValue(value)
    }, delay)
    
    return () => clearTimeout(handler)
  }, [value, delay])
  
  return debouncedValue
}

// Usage in search component
function SearchBar() {
  const [query, setQuery] = useState('')
  const debouncedQuery = useDebounce(query, 300)
  
  useEffect(() => {
    if (debouncedQuery) {
      window.api.search(debouncedQuery)
    }
  }, [debouncedQuery])
  
  return <input value={query} onChange={(e) => setQuery(e.target.value)} />
}
```

