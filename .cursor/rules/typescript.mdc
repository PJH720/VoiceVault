## electron-store Usage Patterns

### Settings Persistence
**File:** `src/main/store.ts`
```typescript
import Store from 'electron-store'
import type { AppSettings } from '@shared/types'

interface StoreSchema {
  settings: AppSettings
  recentRecordings: string[]
}

// ✅ Typed store
export const store = new Store<StoreSchema>({
  defaults: {
    settings: {
      language: 'ko',
      whisperModel: 'base',
      theme: 'system',
      autoSummarize: true
    },
    recentRecordings: []
  }
})

// ✅ Helper functions
export function getSettings(): AppSettings {
  return store.get('settings')
}

export function updateSettings(partial: Partial<AppSettings>): void {
  store.set('settings', { ...getSettings(), ...partial })
}
```

### IPC Handler for Settings
```typescript
// src/main/ipc/settings.ts
import { ipcMain } from 'electron'
import { IpcChannels } from '@shared/ipc-channels'
import { getSettings, updateSettings } from '@main/store'

export function registerSettingsHandlers(): void {
  ipcMain.handle(IpcChannels.SETTINGS_GET, () => {
    return getSettings()
  })
  
  ipcMain.handle(IpcChannels.SETTINGS_UPDATE, (_, partial: Partial<AppSettings>) => {
    updateSettings(partial)
    return getSettings()
  })
}
```

