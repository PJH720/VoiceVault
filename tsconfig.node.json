{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "composite": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {}
  },
  "include": [
    "src/main/**/*",
    "src/shared/**/*",
    "electrobun.config.ts",
    "scripts/**/*.ts"
  ]
}
