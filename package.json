{
  "name": "voice-vault",
  "version": "0.7.0",
  "description": "Record, transcribe, summarize, and organize voice recordings — all on-device",
  "author": "VoiceVault Contributors",
  "license": "MIT",
  "homepage": "https://github.com/PJH720/VoiceVault",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:bun": "tsc --noEmit -p tsconfig.node.json --composite false",
    "predev": "lsof -t -i:50100 -i:5173 2>/dev/null | xargs -r kill -9 || true",
    "dev": "concurrently \"vite src/renderer --port 5173\" \"bash scripts/dev-electrobun.sh\"",
    "build": "vite build src/renderer && bun build src/electrobun/main.ts --outdir out/electrobun/main --target bun",
    "package:linux": "pnpm run build && electrobun package --platform linux",
    "package:mac": "pnpm run build && electrobun package --platform mac",
    "package:win": "pnpm run build && electrobun package --platform win",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:e2e": "playwright test tests/e2e/app-launch.test.ts",
    "test:whisper": "bash scripts/test-whisper.sh",
    "check:translations": "node scripts/check-translations.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.2.1",
    "electrobun": "^1.15.1",
    "handlebars": "^4.7.8",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "openai": "^6.25.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^28.1.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
