# =============================================================================
# VoiceVault — Electrobun + Bun + Vite + React
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.venv/

# ── Build outputs (all generated at build time) ───────────────────────────────
dist/
out/
build/
.vite/

# ── Electrobun native libs (generated by postinstall / electrobun dev) ────────
*.so
*.dylib
*.dll

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Audio / media files (large, user-generated or test fixtures) ──────────────
*.wav
*.mp3
*.ogg
*.webm
*.m4a
*.flac
*.aac
*.opus

# ── AI models (downloaded at runtime, not committed) ─────────────────────────
models/
*.bin
*.gguf
*.ggml

# ── Databases ─────────────────────────────────────────────────────────────────
*.db
*.db-journal
*.db-shm
*.db-wal

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
logs/

# ── Test / coverage artifacts ─────────────────────────────────────────────────
coverage/
coverage.xml
htmlcov/
**/playwright-report/
**/test-results/
.pytest_cache/
.mypy_cache/
.ruff_cache/
**/__pycache__/
*.pyc
*.pyo

# ── Stray prompt / scratch files ──────────────────────────────────────────────
issue-*.txt
prompt-*.txt
*.plan.md

# ── IDE / tool artifacts ──────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
.cursor/
.serena/
.claude/
.eslintcache
*.tsbuildinfo
uv.lock

# ── Python packaging artifacts ────────────────────────────────────────────────
*.egg-info/
*.egg
dist-electron/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
._*
.AppleDouble
.LSOverride

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*~
firebase-debug.log
