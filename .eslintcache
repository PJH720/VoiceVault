ll,"endLine":54,"endColumn":14,"suppressions":"673"},{"ruleId":"671","severity":2,"message":"674","line":26,"column":10,"nodeType":null,"endLine":26,"endColumn":23,"suppressions":"675"},{"ruleId":"671","severity":2,"message":"676","line":44,"column":5,"nodeType":null,"endLine":44,"endColumn":20,"suppressions":"677"},{"ruleId":"671","severity":2,"message":"678","line":39,"column":10,"nodeType":null,"endLine":39,"endColumn":27,"suppressions":"679"},{"ruleId":"680","severity":2,"message":"681","line":18,"column":43,"nodeType":"682","messageId":"683","endLine":18,"endColumn":46,"suggestions":"684","suppressions":"685"},{"ruleId":"680","severity":2,"message":"681","line":26,"column":40,"nodeType":"682","messageId":"683","endLine":26,"endColumn":43,"suggestions":"686","suppressions":"687"},{"ruleId":"680","severity":2,"message":"681","line":38,"column":52,"nodeType":"682","messageId":"683","endLine":38,"endColumn":55,"suggestions":"688","suppressions":"689"},"@typescript-eslint/explicit-function-return-type","Missing return type on function.","FunctionDeclaration","missingReturnType",["690"],["691"],["692"],"react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/pj/dev/VoiceVault/src/renderer/src/components/Audio/AudioSourceSelector.tsx:54:10\n  52 |     // Async data loading on mount — setState is intentional\n  53 |     // eslint-disable-next-line react-hooks/set-state-in-effect\n> 54 |     void load()\n     |          ^^^^ Avoid calling setState() directly within an effect\n  55 |   }, [])\n  56 |\n  57 |   const requestPermission = async (type: 'screen' | 'microphone'): Promise<void> => {",["693"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/pj/dev/VoiceVault/src/renderer/src/components/Templates/TemplateLibrary.tsx:26:10\n  24 |     // Async data loading on mount — setState is intentional\n  25 |     // eslint-disable-next-line react-hooks/set-state-in-effect\n> 26 |     void loadTemplates()\n     |          ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  27 |   }, [])\n  28 |\n  29 |   const removeTemplate = async (id: string): Promise<void> => {",["694"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/pj/dev/VoiceVault/src/renderer/src/components/Translation/BilingualTranscript.tsx:44:5\n  42 |     // Reset + async batch translation — setState is intentional\n  43 |     // eslint-disable-next-line react-hooks/set-state-in-effect\n> 44 |     setTranslations(new Map())\n     |     ^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  45 |     if (translatableSegments.length === 0) return\n  46 |     const sourceLanguage = translatableSegments[0]?.language ?? 'en'\n  47 |     void translateBatch(",["695"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/pj/dev/VoiceVault/src/renderer/src/contexts/LibraryContext.tsx:39:10\n  37 |     // Async data loading on dependency change — setState is intentional\n  38 |     // eslint-disable-next-line react-hooks/set-state-in-effect\n> 39 |     void refreshRecordings()\n     |          ^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  40 |   }, [refreshRecordings])\n  41 |\n  42 |   const selectRecording = useCallback(async (id: number): Promise<void> => {",["696"],"@typescript-eslint/no-explicit-any","Unexpected any. Specify a different type.","TSAnyKeyword","unexpectedAny",["697",